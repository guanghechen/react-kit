{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "guanghechen",
    "url": "https://github.com/guanghechen/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guanghechen/react-kit/tree/release-2.x.x"
  },
  "homepage": "https://github.com/guanghechen/react-kit/tree/release-2.x.x/#readme",
  "engines": {
    "node": ">= 18.0.0"
  },
  "type": "module",
  "scripts": {
    ":publish": "pnpm clean && pnpm build:production && pnpm test:coverage && pnpm -r publish --no-git-checks",
    ":upgrade": "pnpm update -i && pnpm clean && pnpm format && pnpm build && pnpm test",
    "build": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=true pnpm -r run build",
    "build:production": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=false pnpm -r run build",
    "clean": "pnpm -r run clean && pnpm install",
    "format": "pnpm format:lintfix && pnpm format:prettier",
    "format:prettier": "prettier . --write",
    "format:lintfix": "eslint . --fix",
    "prepublishOnly": "pinst --disable",
    "postinstall": "is-ci || husky",
    "postpublish": "pinst --enable",
    "rebuild": "pnpm clean && pnpm build",
    "run:ts": "node --loader ts-node/esm",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:update": "jest -u --passWithNoTests",
    "version": "pnpm install && ghc-doc-link-rewrite && git stage -u pnpm-lock.yaml packages/**/package.json packages/**/*.md",
    ":publish:all": "pnpm -r exec npm version patch --no-git-tag-version && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@guanghechen/eslint-config": "^7.0.20",
    "@guanghechen/eslint-config-jsx": "^6.0.0-alpha.4",
    "@guanghechen/eslint-config-ts": "^6.0.0-alpha.8",
    "@guanghechen/helper-jest": "^6.0.4",
    "@guanghechen/jest-config": "^6.0.4",
    "@guanghechen/rollup-config": "^6.0.11",
    "@guanghechen/script-doc-link": "^6.0.9",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.11",
    "@types/react": "18.3.24",
    "cross-env": "10.0.0",
    "eslint": "9.34.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jest": "30.1.1",
    "lint-staged": "16.1.5",
    "pinst": "3.0.0",
    "prettier": "3.6.2",
    "react": "18.3.1",
    "rimraf": "6.0.1",
    "rollup": "4.49.0",
    "tslib": "2.8.1",
    "ts-jest": "29.4.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,eslintrc}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.2"
}
